<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>الرسائل والاقتراحات - لوحة التحكم</title>
    <link rel="stylesheet" href="../css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Tajawal', sans-serif; }
        .badge {
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
        }
        .badge-suggestion { background: rgba(59, 130, 246, 0.2); color: var(--info-color); }
        .badge-complaint { background: rgba(239, 68, 68, 0.2); color: var(--danger-color); }
        .badge-partnership { background: rgba(139, 92, 246, 0.2); color: var(--vrp-color); }
        .badge-other { background: rgba(107, 114, 128, 0.2); color: var(--text-secondary); }
        .badge-new { background: rgba(59, 130, 246, 0.2); color: var(--info-color); }
        .badge-read { background: rgba(251, 191, 36, 0.2); color: var(--warning-color); }
        .badge-replied { background: rgba(74, 222, 128, 0.2); color: var(--success-color); }
        .badge-closed { background: rgba(107, 114, 128, 0.2); color: var(--text-secondary); }
        .text-center { text-align: center; }
        .text-error { color: var(--danger-color); }
    </style>
</head>
<body class="admin-body">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
        <div class="admin-logo">ارموكس</div>
        <nav class="admin-nav">
            <a href="index.html" class="admin-nav-item">
                <i class="fas fa-home"></i>
                <span>الرئيسية</span>
            </a>
            <a href="servers.html" class="admin-nav-item">
                <i class="fas fa-server"></i>
                <span>السيرفرات</span>
            </a>
            <a href="mods.html" class="admin-nav-item">
                <i class="fas fa-cube"></i>
                <span>المودات</span>
            </a>
            <a href="suggestions.html" class="admin-nav-item active">
                <i class="fas fa-envelope"></i>
                <span>الرسائل</span>
            </a>
            <a href="#" class="admin-nav-item" onclick="logout(); return false;">
                <i class="fas fa-sign-out-alt"></i>
                <span>تسجيل الخروج</span>
            </a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="admin-main">
        <div class="admin-header">
            <h1 class="admin-title">الرسائل والاقتراحات</h1>
        </div>

        <!-- Suggestions Table -->
        <div class="data-table">
            <table id="suggestions-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>الاسم</th>
                        <th>الموضوع</th>
                        <th>النوع</th>
                        <th>الحالة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="6" class="text-center">جاري التحميل...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>

    <!-- Suggestion View Modal -->
    <div class="modal-overlay" id="suggestion-modal">
        <div class="modal" style="max-width: 700px;">
            <div class="modal-header">
                <h3 class="modal-title">عرض الرسالة</h3>
                <button class="modal-close" onclick="closeModal('suggestion-modal')">&times;</button>
            </div>
            <div class="modal-body">
                <div style="margin-bottom: 1.5rem;">
                    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 1rem;">
                        <div>
                            <label style="color: var(--text-secondary); font-size: 0.875rem;">الاسم</label>
                            <p id="suggestion-name" style="font-weight: 600;"></p>
                        </div>
                        <div>
                            <label style="color: var(--text-secondary); font-size: 0.875rem;">البريد الإلكتروني</label>
                            <p id="suggestion-email" style="font-weight: 600;"></p>
                        </div>
                    </div>
                    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 1rem;">
                        <div>
                            <label style="color: var(--text-secondary); font-size: 0.875rem;">النوع</label>
                            <p id="suggestion-type" style="font-weight: 600;"></p>
                        </div>
                        <div>
                            <label style="color: var(--text-secondary); font-size: 0.875rem;">التاريخ</label>
                            <p id="suggestion-date" style="font-weight: 600;"></p>
                        </div>
                    </div>
                    <div>
                        <label style="color: var(--text-secondary); font-size: 0.875rem;">الموضوع</label>
                        <p id="suggestion-subject" style="font-weight: 600;"></p>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">الرسالة</label>
                    <div id="suggestion-message" style="background: var(--dark-bg); padding: 1rem; border-radius: var(--border-radius); line-height: 1.8;"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal('suggestion-modal')">إغلاق</button>
            </div>
        </div>
    </div>

    <script src="../js/main.js"></script>
    <script src="../js/admin.js"></script>
</body>
</html>
